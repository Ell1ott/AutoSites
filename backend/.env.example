# Bearer token required on every API request (defense-in-depth behind Tailscale)
BACKEND_AUTH_TOKEN=change-me

# Where SQLite lives. Default: <repo>/backend/data/leads.db
BACKEND_DB_PATH=

# Where blobs live (screenshots, crawls). Default: <repo>/backend/data
BACKEND_DATA_DIR=

# API bind. On the Pi behind Tailscale this can be 0.0.0.0
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8888

# Max jobs that may run in parallel inside the API process. Default 3.
BACKEND_MAX_CONCURRENT=3

# External APIs used by handlers
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Variant.com browser profile (run: uv run python -m scripts.setup_variant_session)
VARIANT_BROWSER_PROFILE_DIR=
VARIANT_PROJECTS_URL=https://variant.com/projects
VARIANT_SETUP_EMAIL=hi@novine.dk
VARIANT_GENERATION_TIMEOUT_S=900
# Poll until iframe HTML looks rendered (3 polls × 2s = ~6s stable before capture)
VARIANT_GENERATION_STABLE_POLLS=3
VARIANT_POST_READY_SETTLE_MS=4000
