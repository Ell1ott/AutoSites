# Pi / local backend (FastAPI). Default matches backend dev port (:8888).
NEXT_PUBLIC_PI_URL=http://localhost:8888

# Optional; omit in local dev if the backend has no BACKEND_AUTH_TOKEN set.
# NEXT_PUBLIC_BACKEND_TOKEN=

# Supabase (required for /sites — CMS site management)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: origin of the site app serving /auth/callback (default http://localhost:3000)
# CMS_AUTH_CALLBACK_ORIGIN=http://localhost:3000
